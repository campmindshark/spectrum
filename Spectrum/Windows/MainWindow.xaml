<Window
  x:Class="Spectrum.MainWindow"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  mc:Ignorable="d"
  Title="Spectrum Operator Console"
  Height="680"
  Width="980"
  MinHeight="540"
  MinWidth="720"
  ResizeMode="CanResize"
  WindowStartupLocation="CenterScreen"
  Icon="pack://siteoforigin:,,,/Resources/s.PNG"
  Closing="HandleClose">
  <Window.Resources>
    <BooleanToVisibilityConverter x:Key="boolToVis" />
  </Window.Resources>

  <Grid>
    <TabControl x:Name="mainTabs" Margin="7">
      <!-- Readiness first: every number has a label/unit and every warning has
           a direct route to the setup surface that owns it. -->
      <TabItem x:Name="homeTab" Header="Readiness">
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
          <StackPanel Margin="10">
            <Grid Margin="0,0,0,10">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
              </Grid.ColumnDefinitions>
              <StackPanel Grid.Column="0" VerticalAlignment="Center">
                <TextBlock Text="System readiness" Style="{StaticResource WindowTitleText}" />
                <TextBlock Text="Confirm input, engine, dome output, and wands before the show."
                           Style="{StaticResource CaptionText}" Margin="0,3,0,0" TextWrapping="Wrap" />
              </StackPanel>
              <Image Grid.Column="1" Width="180" Height="42" Margin="16,0"
                     Source="pack://siteoforigin:,,,/Resources/spectrum wordmark.PNG"
                     Stretch="Uniform" VerticalAlignment="Center"
                     AutomationProperties.Name="Spectrum" IsHitTestVisible="False" />
              <Border x:Name="overallReadinessBadge" Grid.Column="2" Style="{StaticResource DisabledBadge}"
                      VerticalAlignment="Center" Margin="8,0,0,0">
                <TextBlock x:Name="overallReadinessText" Text="Checking systems…" FontWeight="SemiBold" />
              </Border>
            </Grid>

            <Border Style="{StaticResource SectionCard}" Margin="0,0,0,8">
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="Auto" />
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Button x:Name="powerButton" Grid.Column="0" Content="Start engine"
                        Style="{StaticResource PrimaryButton}" MinWidth="140" MinHeight="46"
                        FontSize="13" Click="PowerButtonClicked" />
                <StackPanel Grid.Column="1" Margin="12,0" VerticalAlignment="Center">
                  <TextBlock Text="Spectrum engine" Style="{StaticResource SectionHeadingText}" Margin="0,0,0,3" />
                  <TextBlock x:Name="engineReadinessDetail" Text="Stopped — output is not being updated."
                             Style="{StaticResource CaptionText}" TextWrapping="Wrap" />
                </StackPanel>
                <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right">
                  <Border x:Name="engineStatusBadge" Style="{StaticResource DisabledBadge}" HorizontalAlignment="Right">
                    <TextBlock x:Name="engineStatusText" Text="● Stopped" FontWeight="SemiBold" />
                  </Border>
                  <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,7,0,0">
                    <Label x:Name="operatorFPSLabel" Content="0" FontFamily="Cascadia Mono, Consolas"
                           FontSize="14" FontWeight="SemiBold" />
                    <TextBlock Text=" FPS" VerticalAlignment="Center" Foreground="{StaticResource MutedTextBrush}" />
                  </StackPanel>
                </StackPanel>
              </Grid>
            </Border>

            <UniformGrid Columns="3" Margin="0,0,-8,0">
              <Border Style="{StaticResource SectionCard}">
                <StackPanel>
                  <DockPanel>
                    <TextBlock Text="Audio input  " Style="{StaticResource SectionHeadingText}" />
                    <Border x:Name="audioStatusBadge" DockPanel.Dock="Right" Style="{StaticResource WarningBadge}" RenderTransformOrigin="2.168,0.286">
                      <TextBlock x:Name="audioStatusText" Text="⚠ Select input" FontWeight="SemiBold" />
                    </Border>
                  </DockPanel>
                  <TextBlock x:Name="audioReadinessDetail" Text="No capture device selected."
                             Style="{StaticResource CaptionText}" TextWrapping="Wrap" MinHeight="30" />
                  <Grid Margin="0,7,0,0">
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="*" />
                      <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <ComboBox x:Name="audioDevices" DisplayMemberPath="name"
                              SelectionChanged="AudioInputDeviceChanged" MinWidth="150" />
                    <Button Grid.Column="1" Content="Refresh" Margin="5,0,0,0"
                            Style="{StaticResource SubtleButton}" Click="RefreshAudioDevices" />
                  </Grid>
                  <TextBlock x:Name="audioSignalText" Text="Signal: 0%" Margin="0,6,0,0"
                             FontFamily="Cascadia Mono, Consolas" />
                </StackPanel>
              </Border>

              <Border Style="{StaticResource SectionCard}">
                <StackPanel>
                  <DockPanel>
                    <TextBlock Text="Dome output  " Style="{StaticResource SectionHeadingText}" />
                    <Border x:Name="domeStatusBadge" DockPanel.Dock="Right" Style="{StaticResource DisabledBadge}">
                      <TextBlock x:Name="domeStatusText" Text="○ Off" FontWeight="SemiBold" />
                    </Border>
                  </DockPanel>
                  <TextBlock x:Name="domeReadinessDetail" Text="Dome output is intentionally off."
                             Style="{StaticResource CaptionText}" TextWrapping="Wrap" MinHeight="30" />
                  <StackPanel Orientation="Horizontal" Margin="0,7,0,0">
                    <TextBlock x:Name="homeDomeFPSLabel" Text="0" Style="{StaticResource TelemetryText}" />
                    <TextBlock Text=" FPS sent by OPC" Margin="5,0,0,0" VerticalAlignment="Center"
                               Foreground="{StaticResource MutedTextBrush}" />
                  </StackPanel>
                  <Button Content="Open dome setup" HorizontalAlignment="Left" Margin="0,6,0,0"
                          Style="{StaticResource HyperlinkButton}" Click="ShowDomeSetup" />
                </StackPanel>
              </Border>

              <Border Style="{StaticResource SectionCard}">
                <StackPanel>
                  <DockPanel>
                    <TextBlock Text="Wands  " Style="{StaticResource SectionHeadingText}" />
                    <Border x:Name="homeWandStatusBadge" DockPanel.Dock="Right" Style="{StaticResource DisabledBadge}">
                      <TextBlock x:Name="homeWandStatusText" Text="○ Off" FontWeight="SemiBold" />
                    </Border>
                  </DockPanel>
                  <TextBlock x:Name="homeWandReadinessDetail" Text="No receiver port selected."
                             Style="{StaticResource CaptionText}" TextWrapping="Wrap" MinHeight="30" />
                  <TextBlock x:Name="connectedWandCountText" Text="0 connected devices" Margin="0,7,0,0"
                             FontFamily="Cascadia Mono, Consolas" FontSize="14" FontWeight="SemiBold" />
                  <Button Content="Open wand setup" HorizontalAlignment="Left" Margin="0,6,0,0"
                          Style="{StaticResource HyperlinkButton}" Click="ShowDomeSetup" />
                </StackPanel>
              </Border>
            </UniformGrid>

            <Border Style="{StaticResource SectionCard}" Margin="0,0,0,0">
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                  <TextBlock Text="Web controller" Style="{StaticResource SectionHeadingText}" />
                  <TextBlock Text="Open this address on a phone or another computer connected to the same network."
                             Style="{StaticResource CaptionText}" TextWrapping="Wrap" />
                  <TextBlock x:Name="webControllerAddress" Text="http://localhost:8080" Margin="0,5,0,0"
                             FontFamily="Cascadia Mono, Consolas" FontSize="13" />
                  <TextBlock x:Name="webControllerStatus" Text="Starting…" Margin="0,4,0,0"
                             Style="{StaticResource CaptionText}" />
                </StackPanel>
                <Button Grid.Column="1" Content="Copy address" Margin="10,0,0,0"
                        VerticalAlignment="Center" Click="CopyWebControllerAddress" />
              </Grid>
            </Border>
          </StackPanel>
        </ScrollViewer>
      </TabItem>

      <TabItem x:Name="midiTab" Header="MIDI setup">
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
          <Grid Margin="10">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" MinWidth="290" />
              <ColumnDefinition Width="*" MinWidth="290" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
              <Border Style="{StaticResource SectionCard}">
                <StackPanel>
                  <TextBlock Text="Configured devices" Style="{StaticResource SectionHeadingText}" />
                  <CheckBox x:Name="midiEnabled" Content="Enable MIDI input" FontWeight="SemiBold" />
                  <ListView x:Name="midiDeviceList" Height="105" Margin="0,6,0,0"
                            ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                            SelectionChanged="MidiDeviceListSelectionChanged">
                    <ListView.View>
                      <GridView>
                        <GridViewColumn Header="Preset" Width="180" DisplayMemberBinding="{Binding PresetName}" />
                        <GridViewColumn Header="Device name" Width="240" DisplayMemberBinding="{Binding DeviceName}" />
                      </GridView>
                    </ListView.View>
                  </ListView>
                  <DockPanel Margin="0,6,0,0">
                    <Button x:Name="midiLoadDevicePreset" Content="Load preset" HorizontalAlignment="Left"
                            Click="MidiLoadPresetClicked" IsEnabled="False" />
                    <Button x:Name="midiDeleteDevice" Content="Remove device" DockPanel.Dock="Right"
                            Style="{StaticResource DestructiveButton}" Click="MidiDeleteDeviceClicked" IsEnabled="False" />
                  </DockPanel>
                  <TextBlock Text="Select a configured device to load its preset or remove it."
                             Style="{StaticResource CaptionText}" Margin="0,7,0,0" />
                </StackPanel>
              </Border>

              <Border Style="{StaticResource SectionCard}">
                <StackPanel>
                  <TextBlock Text="Presets" Style="{StaticResource SectionHeadingText}" />
                  <ListBox x:Name="midiPresetList" Height="85"
                           SelectionChanged="MidiPresetListSelectionChanged" />
                  <WrapPanel Margin="0,6,0,0">
                    <Button x:Name="midiClonePreset" Content="Clone" Click="MidiClonePresetClicked" IsEnabled="False" Margin="0,0,8,0" />
                    <Button x:Name="midiRenamePreset" Content="Rename" Click="MidiRenamePresetClicked" IsEnabled="False" Margin="0,0,8,0" />
                    <Button x:Name="midiDeletePreset" Content="Delete preset" Style="{StaticResource DestructiveButton}"
                            Click="MidiDeletePresetClicked" IsEnabled="False" />
                  </WrapPanel>
                </StackPanel>
              </Border>

              <Border Style="{StaticResource SectionCard}">
                <StackPanel>
                  <TextBlock Text="Bindings in selected preset" Style="{StaticResource SectionHeadingText}" />
                  <ListView x:Name="midiBindingList" Height="110"
                            ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                            SelectionChanged="MidiBindingListSelectionChanged">
                    <ListView.View>
                      <GridView>
                        <GridViewColumn Header="Name" Width="190" DisplayMemberBinding="{Binding BindingName}" />
                        <GridViewColumn Header="Type" Width="230" DisplayMemberBinding="{Binding BindingTypeName}" />
                      </GridView>
                    </ListView.View>
                  </ListView>
                  <DockPanel Margin="0,6,0,0">
                    <Button x:Name="midiEditBinding" Content="Edit binding" Click="MidiEditBindingClicked" IsEnabled="False" />
                    <Button x:Name="midiDeleteBinding" DockPanel.Dock="Right" Content="Delete binding"
                            Style="{StaticResource DestructiveButton}" Click="MidiDeleteBindingClicked" IsEnabled="False" />
                  </DockPanel>
                </StackPanel>
              </Border>

              <Expander Header="Advanced MIDI processing" Margin="0,2,8,8" Foreground="{StaticResource TextBrush}">
                <Border Style="{StaticResource SectionCard}" Margin="0,8,0,0">
                  <CheckBox x:Name="midiThreadCheckbox" Content="Process MIDI on a separate thread" />
                </Border>
              </Expander>
            </StackPanel>

            <StackPanel Grid.Column="1">
              <Border Style="{StaticResource SectionCard}">
                <StackPanel>
                  <TextBlock Text="Add a MIDI device" Style="{StaticResource SectionHeadingText}" />
                  <TextBlock Text="1. Choose a preset" Style="{StaticResource CaptionText}" />
                  <ComboBox x:Name="midiNewDevicePreset" Margin="0,4,0,0"
                            SelectionChanged="MidiNewDeviceSelectionChanged" />
                  <Grid x:Name="midiNewDevicePresetNameGrid" Visibility="Collapsed" Margin="0,6,0,0">
                    <TextBox x:Name="midiNewDevicePresetName" Text="New preset name" FontStyle="Italic"
                             Foreground="Gray" LostFocus="MidiNewDeviceNewPresetNameLostFocus"
                             GotFocus="MidiNewDeviceNewPresetNameGotFocus" />
                  </Grid>
                  <TextBlock Text="2. Choose a connected device" Style="{StaticResource CaptionText}" Margin="0,10,0,0" />
                  <ComboBox x:Name="midiDevices" Margin="0,4,0,0" />
                  <DockPanel Margin="0,9,0,0">
                    <Button Content="Refresh devices" Style="{StaticResource HyperlinkButton}" Click="RefreshMidiDevices" />
                    <Button x:Name="midiAddDevice" DockPanel.Dock="Right" Content="Add device"
                            Style="{StaticResource PrimaryButton}" Click="MidiAddDeviceClicked" />
                  </DockPanel>
                </StackPanel>
              </Border>

              <Border Style="{StaticResource SectionCard}">
                <StackPanel>
                  <Label x:Name="midiPresetEditLabel" Content="Add preset" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,8" />
                  <Grid>
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="*" />
                      <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="midiNewPresetName" Text="New preset name" FontStyle="Italic" Foreground="Gray"
                             LostFocus="MidiNewPresetNameLostFocus" GotFocus="MidiNewPresetNameGotFocus" />
                    <Button x:Name="midiAddPreset" Grid.Column="1" Content="Add preset" Margin="8,0,0,0"
                            Style="{StaticResource PrimaryButton}" Click="MidiAddPresetClicked" />
                    <Button x:Name="midiCancelEditPreset" Grid.Column="1" Content="Cancel" Margin="8,0,0,0"
                            Click="MidiCancelEditPresetClicked" Visibility="Collapsed" />
                  </Grid>
                </StackPanel>
              </Border>

              <Border Style="{StaticResource SectionCard}">
                <StackPanel>
                  <Label x:Name="midiBindingEditLabel" Content="Add binding" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,8" />
                  <TextBlock Text="Binding name" Style="{StaticResource CaptionText}" />
                  <TextBox x:Name="midiNewBindingName" Margin="0,4,0,0" />
                  <TextBlock Text="Binding type" Style="{StaticResource CaptionText}" Margin="0,8,0,0" />
                  <ComboBox x:Name="midiBindingType" Margin="0,4,0,0" SelectionChanged="MidiBindingTypeSelectionChanged">
                    <ComboBoxItem>Change color</ComboBoxItem>
                    <ComboBoxItem>Tap tempo</ComboBoxItem>
                    <ComboBoxItem>Continuous knob</ComboBoxItem>
                    <ComboBoxItem>Discrete knob</ComboBoxItem>
                    <ComboBoxItem>Logarithmic knob</ComboBoxItem>
                    <ComboBoxItem>ADSR level driver</ComboBoxItem>
                  </ComboBox>

                  <StackPanel x:Name="midiChangeColorBindingPanel" Visibility="Collapsed" Margin="0,8,0,0">
                    <TextBlock Text="Start MIDI note" Style="{StaticResource CaptionText}" />
                    <TextBox x:Name="midiChangeColorIndexRangeStart" LostFocus="MidiChangeColorIndexRangeStartLostFocus" />
                  </StackPanel>
                  <StackPanel x:Name="midiTapTempoBindingPanel" Visibility="Collapsed" Margin="0,8,0,0">
                    <TextBlock Text="Button" Style="{StaticResource CaptionText}" />
                    <Grid>
                      <Grid.ColumnDefinitions><ColumnDefinition Width="90" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                      <ComboBox x:Name="midiTapTempoButtonType">
                        <ComboBoxItem>K</ComboBoxItem><ComboBoxItem>P</ComboBoxItem><ComboBoxItem>N</ComboBoxItem>
                      </ComboBox>
                      <TextBox x:Name="midiTapTempoButtonIndex" Grid.Column="1" Margin="8,0,0,0" />
                    </Grid>
                  </StackPanel>
                  <StackPanel x:Name="midiContinuousKnobBindingPanel" Visibility="Collapsed" Margin="0,8,0,0">
                    <TextBlock Text="Knob index" Style="{StaticResource CaptionText}" />
                    <TextBox x:Name="midiContinuousKnobIndex" LostFocus="MidiContinuousKnobIndexLostFocus" />
                    <TextBlock Text="Configuration property" Style="{StaticResource CaptionText}" Margin="0,6,0,0" />
                    <TextBox x:Name="midiContinuousKnobPropertyName" LostFocus="MidiContinuousKnobPropertyNameLostFocus" />
                    <TextBlock Text="Value range" Style="{StaticResource CaptionText}" Margin="0,6,0,0" />
                    <Grid>
                      <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                      <TextBox x:Name="midiContinuousKnobStartValue" LostFocus="MidiContinuousKnobStartValueLostFocus" />
                      <TextBlock Grid.Column="1" Text="to" Margin="8,0" VerticalAlignment="Center" />
                      <TextBox x:Name="midiContinuousKnobEndValue" Grid.Column="2" LostFocus="MidiContinuousKnobEndValueLostFocus" />
                    </Grid>
                  </StackPanel>
                  <StackPanel x:Name="midiDiscreteKnobBindingPanel" Visibility="Collapsed" Margin="0,8,0,0">
                    <TextBlock Text="Knob index" Style="{StaticResource CaptionText}" />
                    <TextBox x:Name="midiDiscreteKnobIndex" LostFocus="MidiDiscreteKnobIndexLostFocus" />
                    <TextBlock Text="Configuration property" Style="{StaticResource CaptionText}" Margin="0,6,0,0" />
                    <TextBox x:Name="midiDiscreteKnobPropertyName" LostFocus="MidiDiscreteKnobPropertyNameLostFocus" />
                    <TextBlock Text="Number of values" Style="{StaticResource CaptionText}" Margin="0,6,0,0" />
                    <TextBox x:Name="midiDiscreteKnobNumPossibleValues" LostFocus="MidiDiscreteKnobNumPossibleValuesLostFocus" />
                  </StackPanel>
                  <StackPanel x:Name="midiLogarithmicKnobBindingPanel" Visibility="Collapsed" Margin="0,8,0,0">
                    <TextBlock Text="Knob index" Style="{StaticResource CaptionText}" />
                    <TextBox x:Name="midiLogarithmicKnobIndex" LostFocus="MidiLogarithmicKnobIndexLostFocus" />
                    <TextBlock Text="Configuration property" Style="{StaticResource CaptionText}" Margin="0,6,0,0" />
                    <TextBox x:Name="midiLogarithmicKnobPropertyName" LostFocus="MidiLogarithmicKnobPropertyNameLostFocus" />
                    <TextBlock Text="Number of values" Style="{StaticResource CaptionText}" Margin="0,6,0,0" />
                    <TextBox x:Name="midiLogarithmicKnobNumPossibleValues" LostFocus="MidiLogarithmicKnobNumPossibleValuesLostFocus" />
                    <TextBlock Text="Starting value" Style="{StaticResource CaptionText}" Margin="0,6,0,0" />
                    <TextBox x:Name="midiLogarithmicKnobStartValue" LostFocus="MidiLogarithmicKnobStartValueLostFocus" />
                  </StackPanel>
                  <StackPanel x:Name="midiAdsrLevelDriverBindingPanel" Visibility="Collapsed" Margin="0,8,0,0">
                    <TextBlock Text="Start MIDI note" Style="{StaticResource CaptionText}" />
                    <TextBox x:Name="midiAdsrLevelDriverIndexRangeStart" LostFocus="MidiAdsrLevelDriverIndexRangeStartLostFocus" />
                  </StackPanel>

                  <DockPanel Margin="0,10,0,0">
                    <Button x:Name="midiCancelEditBinding" Content="Cancel" Click="MidiCancelEditBindingClicked" Visibility="Collapsed" />
                    <Button x:Name="midiAddBinding" DockPanel.Dock="Right" Content="Add binding"
                            Style="{StaticResource PrimaryButton}" Click="MidiAddBindingClicked" IsEnabled="False" />
                  </DockPanel>
                </StackPanel>
              </Border>
            </StackPanel>
          </Grid>
        </ScrollViewer>
      </TabItem>

      <TabItem x:Name="domeTab" Header="Dome setup">
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
          <Grid Margin="10">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" MinWidth="290" />
              <ColumnDefinition Width="*" MinWidth="290" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
              <Border Style="{StaticResource SectionCard}">
                <StackPanel>
                  <TextBlock Text="Dome output" Style="{StaticResource SectionHeadingText}" />
                  <CheckBox x:Name="domeEnabled" Content="Enable dome output" FontWeight="SemiBold" />
                  <TextBlock Text="Maximum brightness" Style="{StaticResource CaptionText}" Margin="0,10,0,0" />
                  <Grid Margin="0,4,0,0">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="60" /></Grid.ColumnDefinitions>
                    <Slider x:Name="domeMaxBrightnessSlider" Value="0.5" Maximum="1.0" LargeChange="0.1" SmallChange="0.001"
                            Thumb.DragStarted="SliderStarted" Thumb.DragCompleted="SliderCompleted" />
                    <Label x:Name="domeMaxBrightnessLabel" Grid.Column="1" Content="50%" HorizontalAlignment="Right" />
                  </Grid>
                  <TextBlock Text="Brightness" Style="{StaticResource CaptionText}" Margin="0,9,0,0" />
                  <Grid Margin="0,4,0,0">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="60" /></Grid.ColumnDefinitions>
                    <Slider x:Name="domeBrightnessSlider" Value="0.1" Maximum="1.0" LargeChange="0.1" SmallChange="0.001"
                            Thumb.DragStarted="SliderStarted" Thumb.DragCompleted="SliderCompleted" />
                    <Label x:Name="domeBrightnessLabel" Grid.Column="1" Content="10%" HorizontalAlignment="Right" />
                  </Grid>
                </StackPanel>
              </Border>

              <Border Style="{StaticResource SectionCard}">
                <StackPanel>
                  <TextBlock Text="OPC controller" Style="{StaticResource SectionHeadingText}" />
                  <TextBlock Text="Host and port" Style="{StaticResource CaptionText}" />
                  <TextBox x:Name="domeBeagleboneOPCHostAndPort" Margin="0,4,0,0"
                           ToolTip="Use host:port or host:port:channel"
                           TextChanged="DomeOpcAddressChanged" LostFocus="DomeOpcAddressLostFocus" />
                  <TextBlock x:Name="domeOPCValidationStatus" Text="Use host:port or host:port:channel."
                             Style="{StaticResource CaptionText}" Margin="0,5,0,0" />
                  <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                    <TextBlock x:Name="domeBeagleboneOPCFPSLabel" Text="0" Style="{StaticResource TelemetryText}" />
                    <TextBlock Text=" FPS sent" Margin="5,0,0,0" VerticalAlignment="Center"
                               Foreground="{StaticResource MutedTextBrush}" />
                  </StackPanel>
                </StackPanel>
              </Border>

              <Border Style="{StaticResource SectionCard}">
                <StackPanel>
                  <TextBlock Text="Wiring and mapping" Style="{StaticResource SectionHeadingText}" />
                  <TextBlock Text="Map controller cables to physical dome sectors with a guided lighting sequence."
                             Style="{StaticResource CaptionText}" TextWrapping="Wrap" />
                  <Button x:Name="domeSetMappingButton" Content="Open dome mapping" HorizontalAlignment="Left"
                          Margin="0,10,0,0" Click="OpenDomeMapping" />
                </StackPanel>
              </Border>

              <Border Style="{StaticResource SectionCard}">
                <StackPanel>
                  <TextBlock Text="Diagnostics" Style="{StaticResource SectionHeadingText}" />
                  <TextBlock Text="Dome test pattern" Style="{StaticResource CaptionText}" />
                  <ComboBox x:Name="domeTestPatternSelector" Margin="0,4,0,0"
                            AutomationProperties.Name="Dome test pattern" />
                  <TextBlock Text="A test pattern temporarily overrides the live dome look. Choose None to resume normal output."
                             Style="{StaticResource CaptionText}" Margin="0,6,0,0"
                             TextWrapping="Wrap" />
                </StackPanel>
              </Border>
            </StackPanel>

            <StackPanel Grid.Column="1">
              <Border Style="{StaticResource SectionCard}">
                <StackPanel>
                  <TextBlock Text="Wand receiver" Style="{StaticResource SectionHeadingText}" />
                  <TextBlock Text="Receiver port" Style="{StaticResource CaptionText}" />
                  <ComboBox x:Name="wandSerialPortSelector" Margin="0,4,0,0"
                            DropDownOpened="WandSerialPortDropDownOpened"
                            SelectionChanged="WandSerialPortSelectionChanged" />
                  <TextBlock x:Name="wandReceiverStatus" Text="No port selected" Margin="0,6,0,0"
                             TextWrapping="Wrap" Foreground="{StaticResource MutedTextBrush}" />
                  <Button x:Name="wandStatusButton" Content="Open wand status" HorizontalAlignment="Left"
                          Margin="0,10,0,0" Click="OpenWandStatus" />
                </StackPanel>
              </Border>

              <Border Style="{StaticResource SectionCard}">
                <StackPanel>
                  <TextBlock Text="Performance windows" Style="{StaticResource SectionHeadingText}" />
                  <CheckBox x:Name="vjHUDEnabled" Content="Show performance HUD"
                            Checked="OpenVJHUD" Unchecked="CloseVJHUD" />
                  <CheckBox x:Name="domeSimulationEnabled" Content="Show dome simulator" Margin="0,4,0,0"
                            Checked="OpenDomeSimulator" Unchecked="CloseDomeSimulator" />
                </StackPanel>
              </Border>

              <Expander Header="Advanced output processing" Margin="0,2,8,8" Foreground="{StaticResource TextBrush}">
                <Border Style="{StaticResource SectionCard}" Margin="0,8,0,0">
                  <StackPanel>
                    <CheckBox x:Name="domeThreadCheckbox" Content="Send dome output on a separate thread" />
                    <TextBlock Text="Changing this setting restarts the engine. Use it only when diagnosing output timing."
                               Style="{StaticResource CaptionText}" Margin="0,6,0,0" TextWrapping="Wrap" />
                  </StackPanel>
                </Border>
              </Expander>
            </StackPanel>
          </Grid>
        </ScrollViewer>
      </TabItem>
    </TabControl>
  </Grid>
</Window>
