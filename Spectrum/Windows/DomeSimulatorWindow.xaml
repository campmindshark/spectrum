<Window
  x:Class="Spectrum.DomeSimulatorWindow"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  Title="Dome Simulator"
  Height="780"
  Width="780"
  MinHeight="460"
  MinWidth="460"
  ResizeMode="CanResize"
  Icon="pack://siteoforigin:,,,/Resources/s.PNG"
  Loaded="WindowLoaded">
  <Grid Margin="12">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>
    <DockPanel Margin="0,0,0,10">
      <ToggleButton x:Name="projectionToggle" Content="View: Strip extents"
                    DockPanel.Dock="Left"
                    ToolTip="Foreshorten the dome as it appears from directly above"
                    Click="ProjectionChanged" />
    </DockPanel>
    <Border Grid.Row="1" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
            CornerRadius="0" Background="Black" ClipToBounds="True">
      <Viewbox Stretch="Uniform">
        <Canvas x:Name="canvas" Width="750" Height="750" Background="Black">
          <Image x:Name="image" Width="750" Height="750" Stretch="Fill" />
        </Canvas>
      </Viewbox>
    </Border>
  </Grid>
</Window>
