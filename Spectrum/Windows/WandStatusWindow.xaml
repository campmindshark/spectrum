<Window
  x:Class="Spectrum.WandStatusWindow"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  xmlns:local="clr-namespace:Spectrum"
  mc:Ignorable="d"
  Title="Wand Status"
  Height="470"
  Width="1115"
  MinHeight="360"
  MinWidth="720"
  ResizeMode="CanResize"
  Icon="pack://siteoforigin:,,,/Resources/s.PNG"
  Loaded="WindowLoaded"
  Closed="WindowClosed"
>
  <Grid Margin="12">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <TextBlock Grid.Row="0" Text="Wand Status" FontSize="18" FontWeight="Bold"
      Foreground="{StaticResource TextBrush}" />

    <TextBlock Grid.Row="1" x:Name="summaryLabel" Margin="0,6,0,8"
      Foreground="{StaticResource MutedTextBrush}" Text="Listening for devices…" />

    <Border Grid.Row="2" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
      CornerRadius="0">
      <ListView x:Name="wandList" Background="Transparent" BorderThickness="0"
        Foreground="{StaticResource TextBrush}" FontFamily="Consolas" FontSize="13">
        <ListView.ItemContainerStyle>
          <Style TargetType="ListViewItem">
            <!-- Whole-row color reflects connection quality (green/amber/red). -->
            <Setter Property="Foreground" Value="{Binding QualityBrush}" />
          </Style>
        </ListView.ItemContainerStyle>
        <ListView.View>
          <GridView>
            <GridViewColumn Header="ID" Width="45"
              DisplayMemberBinding="{Binding DeviceId}" />
            <GridViewColumn Header="Type" Width="90"
              DisplayMemberBinding="{Binding TypeName}" />
            <GridViewColumn Header="Button" Width="65"
              DisplayMemberBinding="{Binding Action}" />
            <GridViewColumn Header="Motion" Width="60"
              DisplayMemberBinding="{Binding Motion}" />
            <GridViewColumn Header="Quality" Width="60"
              DisplayMemberBinding="{Binding Quality}" />
            <GridViewColumn Header="Rate (Hz, ≤200)" Width="90"
              DisplayMemberBinding="{Binding Rate}" />
            <GridViewColumn Header="Jitter (ms)" Width="75"
              DisplayMemberBinding="{Binding Jitter}" />
            <GridViewColumn Header="Loss (%)" Width="65"
              DisplayMemberBinding="{Binding Loss}" />
            <GridViewColumn Header="Data (kB/s)" Width="80"
              DisplayMemberBinding="{Binding DataRate}" />
            <GridViewColumn Header="Packets" Width="75"
              DisplayMemberBinding="{Binding Packets}" />
            <GridViewColumn Header="Last (ms)" Width="70"
              DisplayMemberBinding="{Binding LastSeen}" />
            <GridViewColumn Header="Orientation (W X Y Z)" Width="190"
              DisplayMemberBinding="{Binding Orientation}" />
            <GridViewColumn Header="Speed" Width="65"
              DisplayMemberBinding="{Binding Speed}" />
          </GridView>
        </ListView.View>
      </ListView>
    </Border>

    <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,12,0,0">
      <Button x:Name="calibrateButton" Content="Calibrate All" Width="130"
        Height="25" FontWeight="Bold" Click="CalibrateClicked" />
      <Button x:Name="closeButton" Content="Close" Width="90" Height="25"
        Margin="8,0,0,0" Click="CloseClicked" />
    </StackPanel>
  </Grid>
</Window>
