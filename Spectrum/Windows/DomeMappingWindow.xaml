<Window
  x:Class="Spectrum.DomeMappingWindow"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  mc:Ignorable="d"
  Title="Dome Mapping Calibration"
  Height="900"
  Width="1220"
  MinHeight="680"
  MinWidth="960"
  ResizeMode="CanResize"
  Icon="pack://siteoforigin:,,,/Resources/s.PNG"
  Loaded="WindowLoaded"
  Closed="WindowClosed"
>
  <Grid>
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="3*" MinWidth="560" />
      <ColumnDefinition Width="2*" MinWidth="390" />
    </Grid.ColumnDefinitions>

    <Grid Grid.Column="0" Margin="14">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="*" />
      </Grid.RowDefinitions>

      <DockPanel>
        <StackPanel DockPanel.Dock="Left">
          <TextBlock Text="Logical simulator candidate" FontSize="18"
            FontWeight="Bold" Foreground="{StaticResource TextBrush}" />
          <TextBlock Text="Navigate the candidate here while the physical output stays fixed."
            Margin="0,4,0,0" Foreground="{StaticResource MutedTextBrush}" />
        </StackPanel>
        <Button x:Name="projectionButton" DockPanel.Dock="Right"
          Content="View: Real top-down" Margin="12,0,0,0"
          Padding="10,4" VerticalAlignment="Center"
          Click="ProjectionClicked" />
      </DockPanel>

      <TextBlock x:Name="candidateLabel" Grid.Row="1" Text="Preview is blank"
        Margin="0,10,0,8" FontSize="14" FontWeight="Bold"
        Foreground="{StaticResource WarningBrush}" />

      <Border Grid.Row="2" BorderBrush="{StaticResource BorderBrush}"
        BorderThickness="1" Background="#090B10" Padding="8">
        <Viewbox Stretch="Uniform">
          <Canvas x:Name="candidateCanvas" Width="740" Height="740" />
        </Viewbox>
      </Border>
    </Grid>

    <Border Grid.Column="1" BorderBrush="{StaticResource BorderBrush}"
      BorderThickness="1,0,0,0">
      <ScrollViewer VerticalScrollBarVisibility="Auto"
        HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="16">
          <TextBlock Text="Dome mapping calibration" FontSize="20"
            FontWeight="Bold" Foreground="{StaticResource TextBrush}" />
          <TextBlock x:Name="introLabel" TextWrapping="Wrap" Margin="0,7,0,0"
            Foreground="{StaticResource MutedTextBrush}" />

          <TextBlock x:Name="lockWarning" TextWrapping="Wrap"
            Margin="0,12,0,0" Foreground="{StaticResource ErrorBrush}"
            Visibility="Collapsed" />

          <Border x:Name="frameSummary" BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="1" Margin="0,14,0,0" Padding="10"
            Visibility="Collapsed">
            <StackPanel>
              <TextBlock x:Name="hardwareLabel" TextWrapping="Wrap"
                FontWeight="Bold" Foreground="{StaticResource TextBrush}" />
              <TextBlock x:Name="simulatorLabel" TextWrapping="Wrap"
                Margin="0,6,0,0" Foreground="{StaticResource WarningBrush}" />
            </StackPanel>
          </Border>

          <TextBlock x:Name="progressLabel" TextWrapping="Wrap"
            Margin="0,14,0,0" Foreground="{StaticResource TextBrush}" />

          <WrapPanel x:Name="boxSelector" Margin="0,10,0,0"
            Visibility="Collapsed" />

          <WrapPanel x:Name="actionsPanel" Margin="0,10,0,0" />

          <TextBlock x:Name="statusLabel" TextWrapping="Wrap"
            Margin="0,10,0,0" Foreground="{StaticResource ErrorBrush}" />

          <TextBlock Text="Controller cables → dome endpoints"
            Margin="0,18,0,4" FontWeight="Bold"
            Foreground="{StaticResource TextBrush}" />
          <Border BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="1" Padding="8">
            <TextBlock x:Name="cableReadout" FontFamily="Consolas"
              FontSize="13" TextWrapping="Wrap"
              Foreground="{StaticResource TextBrush}" />
          </Border>

          <TextBlock Text="Physical ports → logical strip paths"
            Margin="0,14,0,4" FontWeight="Bold"
            Foreground="{StaticResource TextBrush}" />
          <Border BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="1" Padding="8">
            <TextBlock x:Name="stripReadout" FontFamily="Consolas"
              FontSize="13" TextWrapping="Wrap"
              Foreground="{StaticResource TextBrush}" />
          </Border>
          <TextBlock Text="~ means an initial guess; [?] is the candidate currently shown."
            TextWrapping="Wrap" Margin="0,6,0,0" FontSize="11"
            Foreground="{StaticResource MutedTextBrush}" />
        </StackPanel>
      </ScrollViewer>
    </Border>
  </Grid>
</Window>
