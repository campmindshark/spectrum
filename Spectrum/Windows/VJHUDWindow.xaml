<Window
  x:Class="Spectrum.VJHUDWindow"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  xmlns:configuration="clr-namespace:Spectrum;assembly=Spectrum.Core"
  xmlns:local="clr-namespace:Spectrum"
  mc:Ignorable="d"
  Title="VJ Heads-Up Display"
  Icon="pack://siteoforigin:,,,/Resources/s.PNG"
  Height="850"
  Width="900"
  MinHeight="600"
  MinWidth="720"
  ResizeMode="CanResize"
  WindowState="Maximized"
  KeyDown="VJHUDKeyDown"
>
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="boolToVis" />
        <local:GradientPreviewConverter x:Key="gradientPreview" />
        <local:LEDColorToBrushConverter x:Key="ledColorToBrush" />
    </Window.Resources>
    <Grid Margin="4">
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="controlRailColumn" Width="280" MinWidth="0" />
            <ColumnDefinition Width="5" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Left column: Tempo, Globals, live palette, presets, Orientation -->
        <ScrollViewer Grid.Column="0" Margin="0,0,4,0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel>
                <Label Content="Tempo" Margin="4,0,0,4" FontSize="13" FontWeight="SemiBold" />
                <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="0"
                        Margin="5,0,5,0" Padding="5">
                    <StackPanel>
                        <DockPanel>
                            <Label Content="BPM:" FontSize="12" FontFamily="Segoe UI Semilight" DockPanel.Dock="Left" Padding="1,5" />
                            <Label x:Name="bpmLabel" Content="[none]" FontSize="12" FontFamily="Segoe UI Semilight" Padding="1,5" />
                        </DockPanel>
                        <DockPanel Margin="0,2,0,0">
                            <RadioButton DockPanel.Dock="Left" Name="tempoSelectorHuman" VerticalAlignment="Center" GroupName="TempoSelector" />
                            <Label Content="Human" FontSize="12" FontFamily="Segoe UI Semilight" Padding="1,5" />
                            <Button x:Name="clearBPMButton" Content="Clear" Padding="5,2" Margin="5,0" Click="ClearTempoButtonClicked" />
                            <Button x:Name="tapTempoButton" Content="Tap" Padding="5,2" Margin="5,0" Click="TapTempoButtonClicked" />
                        </DockPanel>
                        <DockPanel Margin="0,2,0,0">
                            <RadioButton DockPanel.Dock="Left" Name="tempoSelectorMadmom" VerticalAlignment="Center" GroupName="TempoSelector" />
                            <Label Content="Madmom" FontSize="12" FontFamily="Segoe UI Semilight" Padding="1,5" />
                        </DockPanel>
                        <DockPanel Margin="0,2,0,0">
                            <RadioButton DockPanel.Dock="Left" Name="tempoSelectorLink" VerticalAlignment="Center" GroupName="TempoSelector" />
                            <Label Content="Pro DJ Link" FontSize="12" FontFamily="Segoe UI Semilight" Padding="1,5" />
                        </DockPanel>
                    </StackPanel>
                </Border>

                <Label Content="Global speeds" Margin="4,12,0,4" FontSize="13" FontWeight="SemiBold" />
                <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="0"
                        Margin="5,0,5,0" Padding="5">
                    <StackPanel>
                        <DockPanel Margin="0,2,0,0">
                            <Label Content="Fade speed" Width="82" Padding="0" VerticalAlignment="Center" />
                            <Label x:Name="domeGlobalFadeSpeedLabel" DockPanel.Dock="Right" Content="0" Width="34" Padding="0" ContentStringFormat="F3" VerticalAlignment="Center" />
                            <Slider x:Name="domeGlobalFadeSpeedSlider"
                                    Value="{x:Static configuration:SpectrumConfigurationSchema.DomeGlobalFadeSpeedDefault}"
                                    Minimum="{x:Static configuration:SpectrumConfigurationSchema.DomeGlobalFadeSpeedMinimum}"
                                    Maximum="{x:Static configuration:SpectrumConfigurationSchema.DomeGlobalFadeSpeedMaximum}"
                                    VerticalAlignment="Center" LargeChange="1" SmallChange="0.2"
                                    Thumb.DragStarted="SliderStarted" Thumb.DragCompleted="SliderCompleted" />
                        </DockPanel>
                        <DockPanel Margin="0,4,0,0">
                            <Label Content="Hue speed" Width="82" Padding="0" VerticalAlignment="Center" />
                            <Label x:Name="domeGlobalHueSpeedLabel" DockPanel.Dock="Right" Content="0" Width="34" Padding="0" ContentStringFormat="F3" VerticalAlignment="Center" />
                            <Slider x:Name="domeGlobalHueSpeedSlider"
                                    Value="{x:Static configuration:SpectrumConfigurationSchema.DomeGlobalHueSpeedDefault}"
                                    Minimum="{x:Static configuration:SpectrumConfigurationSchema.DomeGlobalHueSpeedMinimum}"
                                    Maximum="{x:Static configuration:SpectrumConfigurationSchema.DomeGlobalHueSpeedMaximum}"
                                    VerticalAlignment="Center" LargeChange="1" SmallChange="0.2"
                                    Thumb.DragStarted="SliderStarted" Thumb.DragCompleted="SliderCompleted" />
                        </DockPanel>
                        <DockPanel Margin="0,4,0,0">
                            <Label Content="Flash rate" Width="82" Padding="0" VerticalAlignment="Center" />
                            <ComboBox x:Name="flashRotationSpeed">
                                <ComboBoxItem x:Name="frs0" Content="0" IsSelected="True" />
                                <ComboBoxItem x:Name="frs1" Content="1/2" />
                                <ComboBoxItem x:Name="frs2" Content="1" />
                                <ComboBoxItem x:Name="frs3" Content="2" />
                                <ComboBoxItem x:Name="frs4" Content="4" />
                                <ComboBoxItem x:Name="frs5" Content="8" />
                                <ComboBoxItem x:Name="frs6" Content="16" />
                                <ComboBoxItem x:Name="frs7" Content="32" />
                            </ComboBox>
                        </DockPanel>
                    </StackPanel>
                </Border>

                <Label Content="Palettes" Margin="4,12,0,4" FontSize="13" FontWeight="SemiBold" />
                <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="0"
                        Margin="5,0,5,0" Padding="5">
                    <StackPanel>
                        <ListBox x:Name="paletteList" Height="150" ScrollViewer.HorizontalScrollBarVisibility="Disabled" ToolTip="Select the live palette to edit">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <ItemsControl ItemsSource="{Binding Colors}" VerticalAlignment="Center">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <StackPanel Orientation="Horizontal" />
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Rectangle Width="10" Height="14" Stroke="{StaticResource BorderBrush}" StrokeThickness="0.5" Fill="{Binding Converter={StaticResource ledColorToBrush}}" />
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                        <TextBlock Text="{Binding Name}" Margin="6,0,0,0" VerticalAlignment="Center" />
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                        <DockPanel Margin="0,4,0,0">
                            <Button x:Name="paletteDeleteButton" DockPanel.Dock="Right" Content="Delete" Width="52" ToolTip="Delete selected palette" />
                            <Button x:Name="paletteAddButton" DockPanel.Dock="Right" Content="Add copy" Width="66" Margin="4,0,4,0" ToolTip="Duplicate the selected colors under this name" />
                            <Button x:Name="paletteRenameButton" DockPanel.Dock="Right" Content="Rename" Width="56" Margin="4,0,4,0" ToolTip="Rename the selected palette" />
                            <TextBox x:Name="paletteNameBox" VerticalContentAlignment="Center" ToolTip="Palette name" />
                        </DockPanel>
                    </StackPanel>
                </Border>

                <Label Content="Selected palette colors" Margin="4,12,0,4" FontSize="13" FontWeight="SemiBold" />
                <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="0"
                        Margin="5,0,5,0" Padding="5">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="24" />
                                <ColumnDefinition Width="30" />
                                <ColumnDefinition Width="30" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Label Grid.Column="1" Content="Start" Padding="0" FontSize="10" FontFamily="Segoe UI Semilight" />
                            <Label Grid.Column="2" Content="End" Padding="0" FontSize="10" FontFamily="Segoe UI Semilight" />
                            <Label Grid.Column="3" Content="Preview" Padding="2,0,0,0" FontSize="10" FontFamily="Segoe UI Semilight" />
                        </Grid>
                        <!-- Eight slots of the named palette selected below. -->
                        <Grid Margin="0,2,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="24" />
                                <ColumnDefinition Width="30" />
                                <ColumnDefinition Width="30" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Label Grid.Column="0" Content="0" Padding="0" VerticalAlignment="Center" FontFamily="Segoe UI Semilight" />
                            <local:ColorPicker x:Name="livecolor0_0" Grid.Column="1" Width="24" Height="20" HorizontalAlignment="Left" />
                            <local:ColorPicker x:Name="livecolor0_1" Grid.Column="2" Width="24" Height="20" HorizontalAlignment="Left" />
                            <Rectangle Grid.Column="3" Height="20" Margin="2,0,0,0" Stroke="{StaticResource BorderBrush}" StrokeThickness="1">
                                <Rectangle.Fill>
                                    <MultiBinding Converter="{StaticResource gradientPreview}">
                                        <Binding ElementName="livecolor0_0" Path="SelectedColor" />
                                        <Binding ElementName="livecolor0_1" Path="SelectedColor" />
                                    </MultiBinding>
                                </Rectangle.Fill>
                            </Rectangle>
                        </Grid>
                        <Grid Margin="0,2,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="24" />
                                <ColumnDefinition Width="30" />
                                <ColumnDefinition Width="30" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Label Grid.Column="0" Content="1" Padding="0" VerticalAlignment="Center" FontFamily="Segoe UI Semilight" />
                            <local:ColorPicker x:Name="livecolor1_0" Grid.Column="1" Width="24" Height="20" HorizontalAlignment="Left" />
                            <local:ColorPicker x:Name="livecolor1_1" Grid.Column="2" Width="24" Height="20" HorizontalAlignment="Left" />
                            <Rectangle Grid.Column="3" Height="20" Margin="2,0,0,0" Stroke="{StaticResource BorderBrush}" StrokeThickness="1">
                                <Rectangle.Fill>
                                    <MultiBinding Converter="{StaticResource gradientPreview}">
                                        <Binding ElementName="livecolor1_0" Path="SelectedColor" />
                                        <Binding ElementName="livecolor1_1" Path="SelectedColor" />
                                    </MultiBinding>
                                </Rectangle.Fill>
                            </Rectangle>
                        </Grid>
                        <Grid Margin="0,2,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="24" />
                                <ColumnDefinition Width="30" />
                                <ColumnDefinition Width="30" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Label Grid.Column="0" Content="2" Padding="0" VerticalAlignment="Center" FontFamily="Segoe UI Semilight" />
                            <local:ColorPicker x:Name="livecolor2_0" Grid.Column="1" Width="24" Height="20" HorizontalAlignment="Left" />
                            <local:ColorPicker x:Name="livecolor2_1" Grid.Column="2" Width="24" Height="20" HorizontalAlignment="Left" />
                            <Rectangle Grid.Column="3" Height="20" Margin="2,0,0,0" Stroke="{StaticResource BorderBrush}" StrokeThickness="1">
                                <Rectangle.Fill>
                                    <MultiBinding Converter="{StaticResource gradientPreview}">
                                        <Binding ElementName="livecolor2_0" Path="SelectedColor" />
                                        <Binding ElementName="livecolor2_1" Path="SelectedColor" />
                                    </MultiBinding>
                                </Rectangle.Fill>
                            </Rectangle>
                        </Grid>
                        <Grid Margin="0,2,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="24" />
                                <ColumnDefinition Width="30" />
                                <ColumnDefinition Width="30" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Label Grid.Column="0" Content="3" Padding="0" VerticalAlignment="Center" FontFamily="Segoe UI Semilight" />
                            <local:ColorPicker x:Name="livecolor3_0" Grid.Column="1" Width="24" Height="20" HorizontalAlignment="Left" />
                            <local:ColorPicker x:Name="livecolor3_1" Grid.Column="2" Width="24" Height="20" HorizontalAlignment="Left" />
                            <Rectangle Grid.Column="3" Height="20" Margin="2,0,0,0" Stroke="{StaticResource BorderBrush}" StrokeThickness="1">
                                <Rectangle.Fill>
                                    <MultiBinding Converter="{StaticResource gradientPreview}">
                                        <Binding ElementName="livecolor3_0" Path="SelectedColor" />
                                        <Binding ElementName="livecolor3_1" Path="SelectedColor" />
                                    </MultiBinding>
                                </Rectangle.Fill>
                            </Rectangle>
                        </Grid>
                        <Grid Margin="0,2,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="24" />
                                <ColumnDefinition Width="30" />
                                <ColumnDefinition Width="30" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Label Grid.Column="0" Content="4" Padding="0" VerticalAlignment="Center" FontFamily="Segoe UI Semilight" />
                            <local:ColorPicker x:Name="livecolor4_0" Grid.Column="1" Width="24" Height="20" HorizontalAlignment="Left" />
                            <local:ColorPicker x:Name="livecolor4_1" Grid.Column="2" Width="24" Height="20" HorizontalAlignment="Left" />
                            <Rectangle Grid.Column="3" Height="20" Margin="2,0,0,0" Stroke="{StaticResource BorderBrush}" StrokeThickness="1">
                                <Rectangle.Fill>
                                    <MultiBinding Converter="{StaticResource gradientPreview}">
                                        <Binding ElementName="livecolor4_0" Path="SelectedColor" />
                                        <Binding ElementName="livecolor4_1" Path="SelectedColor" />
                                    </MultiBinding>
                                </Rectangle.Fill>
                            </Rectangle>
                        </Grid>
                        <Grid Margin="0,2,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="24" />
                                <ColumnDefinition Width="30" />
                                <ColumnDefinition Width="30" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Label Grid.Column="0" Content="5" Padding="0" VerticalAlignment="Center" FontFamily="Segoe UI Semilight" />
                            <local:ColorPicker x:Name="livecolor5_0" Grid.Column="1" Width="24" Height="20" HorizontalAlignment="Left" />
                            <local:ColorPicker x:Name="livecolor5_1" Grid.Column="2" Width="24" Height="20" HorizontalAlignment="Left" />
                            <Rectangle Grid.Column="3" Height="20" Margin="2,0,0,0" Stroke="{StaticResource BorderBrush}" StrokeThickness="1">
                                <Rectangle.Fill>
                                    <MultiBinding Converter="{StaticResource gradientPreview}">
                                        <Binding ElementName="livecolor5_0" Path="SelectedColor" />
                                        <Binding ElementName="livecolor5_1" Path="SelectedColor" />
                                    </MultiBinding>
                                </Rectangle.Fill>
                            </Rectangle>
                        </Grid>
                        <Grid Margin="0,2,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="24" />
                                <ColumnDefinition Width="30" />
                                <ColumnDefinition Width="30" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Label Grid.Column="0" Content="6" Padding="0" VerticalAlignment="Center" FontFamily="Segoe UI Semilight" />
                            <local:ColorPicker x:Name="livecolor6_0" Grid.Column="1" Width="24" Height="20" HorizontalAlignment="Left" />
                            <local:ColorPicker x:Name="livecolor6_1" Grid.Column="2" Width="24" Height="20" HorizontalAlignment="Left" />
                            <Rectangle Grid.Column="3" Height="20" Margin="2,0,0,0" Stroke="{StaticResource BorderBrush}" StrokeThickness="1">
                                <Rectangle.Fill>
                                    <MultiBinding Converter="{StaticResource gradientPreview}">
                                        <Binding ElementName="livecolor6_0" Path="SelectedColor" />
                                        <Binding ElementName="livecolor6_1" Path="SelectedColor" />
                                    </MultiBinding>
                                </Rectangle.Fill>
                            </Rectangle>
                        </Grid>
                        <Grid Margin="0,2,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="24" />
                                <ColumnDefinition Width="30" />
                                <ColumnDefinition Width="30" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Label Grid.Column="0" Content="7" Padding="0" VerticalAlignment="Center" FontFamily="Segoe UI Semilight" />
                            <local:ColorPicker x:Name="livecolor7_0" Grid.Column="1" Width="24" Height="20" HorizontalAlignment="Left" />
                            <local:ColorPicker x:Name="livecolor7_1" Grid.Column="2" Width="24" Height="20" HorizontalAlignment="Left" />
                            <Rectangle Grid.Column="3" Height="20" Margin="2,0,0,0" Stroke="{StaticResource BorderBrush}" StrokeThickness="1">
                                <Rectangle.Fill>
                                    <MultiBinding Converter="{StaticResource gradientPreview}">
                                        <Binding ElementName="livecolor7_0" Path="SelectedColor" />
                                        <Binding ElementName="livecolor7_1" Path="SelectedColor" />
                                    </MultiBinding>
                                </Rectangle.Fill>
                            </Rectangle>
                        </Grid>
                    </StackPanel>
                </Border>

                <Label Content="Wand controls" Margin="4,12,0,4" FontSize="13" FontWeight="SemiBold" />
                <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="0"
                        Margin="5,0,5,0" Padding="5">
                    <StackPanel>
                        <TextBlock x:Name="wandSpotlightSummary" Text="Listening for devices&#8230;" TextWrapping="Wrap" FontSize="11" Margin="0,0,0,4" />
                        <!-- The two spotlight modes (all wands / idle) plus the
                             per-row radios below act as one selection over
                             config.orientationDeviceSpotlight (-1 all, -2 idle,
                             else a device id). Mutual exclusion is driven in code
                             (UpdateSpotlightSelection), not GroupName, so the
                             external state stays the single source of truth. -->
                        <RadioButton x:Name="spotlightAllWands" Content="Spotlight: all wands" FontSize="12" Margin="0,1" />
                        <RadioButton x:Name="spotlightIdle" Content="Idle (no wands)" FontSize="12" Margin="0,1,0,4" />
                        <ListView x:Name="wandSpotlightList" BorderThickness="0" Background="Transparent" FontFamily="Consolas" FontSize="12"
                          ScrollViewer.HorizontalScrollBarVisibility="Disabled" ScrollViewer.VerticalScrollBarVisibility="Disabled">
                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem">
                                    <!-- Whole-row color reflects connection quality. -->
                                    <Setter Property="Foreground" Value="{Binding QualityBrush}" />
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                </Style>
                            </ListView.ItemContainerStyle>
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Header="ID" Width="28" DisplayMemberBinding="{Binding DeviceId}" />
                                    <GridViewColumn Header="Type" Width="66" DisplayMemberBinding="{Binding TypeName}" />
                                    <GridViewColumn Header="Motion" Width="50" DisplayMemberBinding="{Binding Motion}" />
                                    <GridViewColumn Header="Quality" Width="52" DisplayMemberBinding="{Binding Quality}" />
                                    <GridViewColumn Header="Spot" Width="40">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <RadioButton HorizontalAlignment="Center" IsChecked="{Binding IsSpotlight, Mode=TwoWay}"
                                                  ToolTip="Spotlight only this wand" />
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                </GridView>
                            </ListView.View>
                        </ListView>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <GridSplitter x:Name="controlRailSplitter" Grid.Column="1" Width="5"
                      HorizontalAlignment="Stretch" ResizeDirection="Columns"
                      ResizeBehavior="PreviousAndNext" Background="{StaticResource BorderBrush}" />

        <!-- Right column: Scenes bar + layer stack -->
        <DockPanel Grid.Column="2" Margin="4,0,0,0">
            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="5,0,0,6">
                <Button x:Name="toggleControlRailButton"
                        Content="Hide setup controls" HorizontalAlignment="Left"
                        Style="{StaticResource SubtleButton}"
                        Click="ToggleControlRail" />
                <Button Content="Shortcuts" HorizontalAlignment="Left"
                        Style="{StaticResource SubtleButton}" Margin="6,0,0,0"
                        Click="ToggleShortcutReference" />
            </StackPanel>
            <Border x:Name="shortcutReference" DockPanel.Dock="Top"
                    Style="{StaticResource SectionCard}" Margin="5,0,5,8"
                    Visibility="Collapsed">
                <TextBlock Text="T  Tap tempo     C  Clear tempo     A  Add layer     F1  Show/hide shortcuts"
                           TextWrapping="Wrap" Style="{StaticResource CaptionText}" />
            </Border>
            <Label DockPanel.Dock="Top" Content="Scenes" Margin="4,0,0,4" FontSize="13" FontWeight="SemiBold" />
            <Border DockPanel.Dock="Top" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="0"
                    Margin="5,0,5,0" Padding="5">
                <DockPanel LastChildFill="True">
                    <Button x:Name="domeSceneDeleteButton" DockPanel.Dock="Right" Content="Delete" Width="52" ToolTip="Delete selected scene" />
                    <Button x:Name="domeSceneSaveButton" DockPanel.Dock="Right" Content="Save" Width="44" Margin="4,0,4,0" ToolTip="Save current look under this name" />
                    <Button x:Name="domeSceneLoadButton" DockPanel.Dock="Right" Content="Load" Width="44" Margin="4,0,4,0" ToolTip="Apply selected scene" />
                    <ComboBox x:Name="domeScenesCombo" DockPanel.Dock="Left" Width="150" ToolTip="Saved scenes" />
                    <TextBox x:Name="domeSceneNameBox" Margin="4,0,4,0" VerticalContentAlignment="Center" ToolTip="Scene name" />
                </DockPanel>
            </Border>

            <DockPanel DockPanel.Dock="Top" Margin="4,12,5,4" LastChildFill="True">
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button x:Name="domeCollapseAllLayersButton" Content="Collapse All"
                            Style="{StaticResource SubtleButton}" ToolTip="Collapse every layer's settings" />
                    <Button x:Name="domeExpandAllLayersButton" Content="Expand All" Margin="4,0,0,0"
                            Style="{StaticResource SubtleButton}" ToolTip="Expand every layer's settings" />
                </StackPanel>
                <Label Content="Layers (top = front)" Margin="0" FontSize="13" FontWeight="SemiBold" />
            </DockPanel>
            <Button DockPanel.Dock="Bottom" x:Name="domeAddLayerButton" Content="Add layer" HorizontalAlignment="Left" Width="90" Margin="5,4,0,0" />
            <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="0"
                    Margin="5,0,5,0" Padding="5">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <ItemsControl x:Name="domeLayersItemsControl">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border CornerRadius="0" Margin="0,2,0,2" Padding="5">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
                                            <Setter Property="BorderThickness" Value="1" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding LayerEnabled}" Value="True">
                                                    <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                                    <Setter Property="BorderThickness" Value="2" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <StackPanel>
                                        <DockPanel LastChildFill="True">
                                            <Button DockPanel.Dock="Right" Content="Remove" Command="{Binding RemoveCommand}" MinWidth="58" ToolTip="Remove layer" />
                                            <CheckBox DockPanel.Dock="Right" Content="On" IsChecked="{Binding LayerEnabled}" VerticalAlignment="Center" Margin="0,0,6,0" ToolTip="Enable this layer" />
                                            <Button DockPanel.Dock="Right" Content="↓" Command="{Binding MoveDownCommand}" Width="28" Padding="0" FontSize="15" ToolTip="Move down toward back" AutomationProperties.Name="Move layer down toward back" />
                                            <Button DockPanel.Dock="Right" Content="↑" Command="{Binding MoveUpCommand}" Width="28" Padding="0" FontSize="15" ToolTip="Move up toward front" AutomationProperties.Name="Move layer up toward front" />
                                            <Button DockPanel.Dock="Right" Content="{Binding ClearLabel}" Command="{Binding ClearCommand}" MinWidth="50" ToolTip="{Binding ClearToolTip}" Visibility="{Binding HasClearAction, Converter={StaticResource boolToVis}}" />
                                            <Button DockPanel.Dock="Right" Content="{Binding FireLabel}" Command="{Binding FireCommand}" MinWidth="46" ToolTip="{Binding FireToolTip}" Visibility="{Binding HasFireAction, Converter={StaticResource boolToVis}}" />
                                            <ToggleButton DockPanel.Dock="Left" IsChecked="{Binding IsExpanded}" Width="24" Margin="0,0,4,0" ToolTip="Expand or collapse layer settings">
                                                <ToggleButton.Style>
                                                    <Style TargetType="ToggleButton">
                                                        <Setter Property="Content" Value="+" />
                                                        <Setter Property="FontSize" Value="15" />
                                                        <Style.Triggers>
                                                            <Trigger Property="IsChecked" Value="True">
                                                                <Setter Property="Content" Value="&#x2212;" />
                                                            </Trigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </ToggleButton.Style>
                                            </ToggleButton>
                                            <ComboBox ItemsSource="{Binding VisualizerOptions}" SelectedValuePath="Key" DisplayMemberPath="Label" SelectedValue="{Binding VisualizerKey}" />
                                        </DockPanel>
                                        <StackPanel Visibility="{Binding IsExpanded, Converter={StaticResource boolToVis}}">
                                            <TextBox Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}" Margin="0,2,0,0" FontSize="10" ToolTip="Notes to yourself about this layer" />
                                            <DockPanel LastChildFill="True" Margin="0,2,0,0">
                                                <TextBlock DockPanel.Dock="Right" Text="{Binding Opacity, StringFormat={}{0:P0}}"
                                                           MinWidth="38" Margin="5,0" VerticalAlignment="Center"
                                                           HorizontalAlignment="Right" FontFamily="Cascadia Mono, Consolas" />
                                                <ComboBox DockPanel.Dock="Left" ItemsSource="{Binding BlendModes}" DisplayMemberPath="Label" SelectedValuePath="Id" SelectedValue="{Binding BlendMode}" Width="96" ToolTip="Blend mode" />
                                                <Slider Minimum="0" Maximum="1" Value="{Binding Opacity}" VerticalAlignment="Center" Margin="4,0,4,0" ToolTip="Opacity" />
                                            </DockPanel>
                                            <ItemsControl ItemsSource="{Binding Params}" Margin="0,2,0,0">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Grid Margin="0,1,0,0">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="140" />
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="48" />
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Grid.Column="0" Text="{Binding Label}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                                            <Slider Grid.Column="1" Minimum="{Binding Min}" Maximum="{Binding Max}" Value="{Binding Value}" VerticalAlignment="Center" Visibility="{Binding IsDouble, Converter={StaticResource boolToVis}}" />
                                                            <TextBlock Grid.Column="2" Text="{Binding Value, StringFormat={}{0:F2}}" VerticalAlignment="Center"
                                                                       HorizontalAlignment="Right" FontFamily="Cascadia Mono, Consolas"
                                                                       Visibility="{Binding IsDouble, Converter={StaticResource boolToVis}}" />
                                                            <CheckBox Grid.Column="1" Content="On" IsChecked="{Binding BoolValue}" VerticalAlignment="Center" HorizontalAlignment="Left" Visibility="{Binding IsBool, Converter={StaticResource boolToVis}}" />
                                                            <ComboBox Grid.Column="1" ItemsSource="{Binding Options}" SelectedIndex="{Binding IntValue}" Visibility="{Binding IsEnum, Converter={StaticResource boolToVis}}" />
                                                            <local:ColorPicker Grid.Column="1" SelectedColor="{Binding ColorValue}" HorizontalAlignment="Left" Width="34" Height="30" Visibility="{Binding IsColor, Converter={StaticResource boolToVis}}" />
                                                            <TextBox Grid.Column="1" Grid.ColumnSpan="2" Text="{Binding DateText, UpdateSourceTrigger=LostFocus, ValidatesOnExceptions=True}" ToolTip="YYYY-MM-DD" Visibility="{Binding IsDate, Converter={StaticResource boolToVis}}" />
                                                        </Grid>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>
        </DockPanel>
    </Grid>
</Window>
